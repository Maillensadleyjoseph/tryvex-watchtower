[Unit]
Description=Watchtower Backend 2
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/watchtower
EnvironmentFile=/opt/watchtower/env
Environment="INSTANCE_NAME=backend-2"
ExecStart=/home/ec2-user/.local/bin/uvicorn main:app --host 0.0.0.0 --port 3001 --log-level warning
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
