# Watchtower - Variables de Entorno
# Copiar como .env y completar con valores reales

# Base de datos (via PgBouncer)
DB_HOST=127.0.0.1
DB_PORT=6432
DB_NAME=watchtower
DB_USER=appuser
DB_PASSWORD=your_secure_password_here

# SMTP Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password_16chars
ALERT_TO=your@gmail.com,backup@inacapmail.cl

# Identificacion de instancia
INSTANCE_NAME=backend-1
